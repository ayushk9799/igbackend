# Existing application configuration
MONGODB_URI=
NODE_ENV=development

# RevenueCat: keep both values server-side only.
REVENUECAT_WEBHOOK_SECRET=
# This implementation uses RevenueCat REST API v1 customer verification.
REVENUECAT_V1_SECRET_API_KEY=
REVENUECAT_PREMIUM_ENTITLEMENT_ID=premium

# Set true only when production should accept sandbox subscription access.
REVENUECAT_ALLOW_SANDBOX=false

# Optional local-only webhook bypass. Never enable in production.
REVENUECAT_ALLOW_INSECURE_WEBHOOKS=false

# Optional: keep an auto-renewing subscription active briefly while the store
# and RevenueCat deliver the next renewal (default: 600000 = 10 minutes).
SUBSCRIPTION_RENEWAL_HANDOFF_MS=600000
